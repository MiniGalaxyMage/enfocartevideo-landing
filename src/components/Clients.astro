---
const clients = [
  {
    name: 'CMM Play',
    fullName: 'Castilla-La Mancha Media',
    description: 'Televisión pública regional',
    initials: 'CMM',
    color: '#E63946',
  },
  {
    name: 'Manchego CF',
    fullName: 'Club de Fútbol Manchego',
    description: 'Fútbol profesional Ciudad Real',
    initials: 'MCF',
    color: '#D4A017',
  },
  {
    name: 'BM Caserío',
    fullName: 'Balonmano Caserío',
    description: 'Club de balonmano',
    initials: 'BM',
    color: '#6366f1',
  },
  {
    name: 'Quixote Arena',
    fullName: 'Quixote Arena',
    description: 'Espacio de eventos deportivos',
    initials: 'QA',
    color: '#10b981',
  },
  {
    name: 'Quixote World Cup',
    fullName: 'Quixote World Cup',
    description: 'Campeonato Mundial de Freestyle',
    initials: 'QWC',
    color: '#ec4899',
  },
];
---

<section class="clients section section--light" id="clientes">
  <div class="container">
    <div class="clients__header reveal">
      <span class="section-label">Confianza</span>
      <h2 class="clients__title">Clientes y Colaboradores</h2>
      <hr class="divider" />
      <p class="clients__intro">
        Trabajamos con organizaciones que exigen la máxima calidad en cada producción.
      </p>
    </div>

    <div class="clients__grid">
      {clients.map((client, i) => (
        <div class={`client-card reveal reveal-delay-${i + 1}`} style={`--client-color: ${client.color}`}>
          <div class="client-card__logo">
            <span class="client-card__initials">{client.initials}</span>
          </div>
          <div class="client-card__info">
            <span class="client-card__name">{client.name}</span>
            <span class="client-card__desc">{client.description}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="clients__quote reveal">
      <blockquote class="clients__blockquote">
        <p>
          "Producción audiovisual que lleva el deporte regional a todas las pantallas,
          con la calidad que el aficionado merece."
        </p>
        <footer>— EnfocarteVideo, Ciudad Real</footer>
      </blockquote>
    </div>
  </div>
</section>

<style>
  .clients__header {
    max-width: 560px;
    margin-bottom: 3rem;
  }

  .clients__title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--color-text-dark);
  }

  .clients__intro {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .clients__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  /* ---- Client card ---- */
  .client-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background-color: #fff;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .client-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    border-color: var(--client-color);
  }

  .client-card__logo {
    width: 52px;
    height: 52px;
    border-radius: 10px;
    background-color: var(--client-color);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .client-card__initials {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 900;
    color: white;
    letter-spacing: 0.03em;
  }

  .client-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .client-card__name {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-dark);
  }

  .client-card__desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* ---- Quote ---- */
  .clients__quote {
    background: linear-gradient(135deg, #1A1A1A 0%, #2a2a2a 100%);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    border-left: 4px solid var(--color-secondary);
  }

  .clients__blockquote {
    font-style: italic;
  }

  .clients__blockquote p {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .clients__blockquote footer {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  /* ---- Responsive ---- */
  @media (min-width: 480px) {
    .clients__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .clients__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .clients__grid {
      grid-template-columns: repeat(5, 1fr);
    }

    .client-card {
      flex-direction: column;
      text-align: center;
      justify-content: center;
      padding: 1.75rem 1.25rem;
    }

    .client-card__info {
      align-items: center;
    }
  }
</style>
