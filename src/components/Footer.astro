---
const year = new Date().getFullYear();

const links = {
  nav: [
    { href: '#servicios', label: 'Servicios' },
    { href: '#portfolio', label: 'Portfolio' },
    { href: '#clientes', label: 'Clientes' },
    { href: '#nosotros', label: 'Nosotros' },
    { href: '#contacto', label: 'Contacto' },
  ],
  legal: [
    { href: '/privacidad', label: 'Política de Privacidad' },
    { href: '/legal', label: 'Aviso Legal' },
  ],
  social: [
    {
      href: 'https://www.instagram.com/enfocartevideo',
      label: 'Instagram',
      icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/>
        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
      </svg>`,
    },
    {
      href: 'https://www.youtube.com/@dnkixote',
      label: 'YouTube',
      icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58Z" stroke="currentColor" stroke-width="2"/>
        <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor"/>
      </svg>`,
    },
  ],
};
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="EnfocarteVideo">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <rect width="36" height="36" rx="8" fill="#E63946"/>
            <path d="M12 11 L25 18 L12 25 Z" fill="white"/>
          </svg>
          <span class="footer__logo-text">EnfocarteVideo</span>
        </a>
        <p class="footer__tagline">
          Producción audiovisual y streaming deportivo<br>en Ciudad Real.
        </p>
        <!-- Social icons -->
        <div class="footer__social">
          {links.social.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__social-link"
              aria-label={s.label}
              set:html={s.icon}
            />
          ))}
        </div>
      </div>

      <!-- Nav links -->
      <nav class="footer__nav" aria-label="Pie de página — Navegación">
        <h4 class="footer__nav-title">Secciones</h4>
        <ul class="footer__nav-list">
          {links.nav.map(link => (
            <li>
              <a href={link.href} class="footer__nav-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div class="footer__contact">
        <h4 class="footer__nav-title">Contacto</h4>
        <ul class="footer__contact-list">
          <li>
            <a href="https://www.instagram.com/enfocartevideo" target="_blank" rel="noopener noreferrer" class="footer__contact-item">
              @enfocartevideo
            </a>
          </li>
          <li>
            <a href="https://www.youtube.com/@dnkixote" target="_blank" rel="noopener noreferrer" class="footer__contact-item">
              @dnkixote
            </a>
          </li>
          <li>
            <a href="mailto:hola@enfocartevideo.com" class="footer__contact-item">
              hola@enfocartevideo.com
            </a>
          </li>
          <li class="footer__contact-location">
            Ciudad Real, Castilla-La Mancha
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {year} EnfocarteVideo. Todos los derechos reservados.
      </p>
      <div class="footer__legal-links">
        {links.legal.map(link => (
          <a href={link.href} class="footer__legal-link">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #111;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    color: var(--color-text-light);
  }

  /* ---- Top ---- */
  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: 3.5rem;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .footer__logo-text {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text-light);
    letter-spacing: -0.02em;
  }

  .footer__tagline {
    font-size: 0.88rem;
    color: rgba(248, 249, 250, 0.45);
    line-height: 1.65;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: rgba(248, 249, 250, 0.6);
    transition: background-color var(--transition), color var(--transition), border-color var(--transition);
  }

  .footer__social-link:hover {
    background-color: var(--color-secondary);
    border-color: var(--color-secondary);
    color: #fff;
  }

  /* ---- Nav columns ---- */
  .footer__nav-title {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(248, 249, 250, 0.35);
    margin-bottom: 1rem;
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__nav-link {
    font-size: 0.9rem;
    color: rgba(248, 249, 250, 0.6);
    transition: color var(--transition);
  }

  .footer__nav-link:hover {
    color: var(--color-text-light);
  }

  .footer__contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__contact-item {
    font-size: 0.9rem;
    color: rgba(248, 249, 250, 0.6);
    transition: color var(--transition);
    text-decoration: none;
  }

  .footer__contact-item:hover {
    color: var(--color-secondary);
  }

  .footer__contact-location {
    font-size: 0.82rem;
    color: rgba(248, 249, 250, 0.35);
    margin-top: 0.25rem;
  }

  /* ---- Bottom bar ---- */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__copy {
    font-size: 0.8rem;
    color: rgba(248, 249, 250, 0.35);
  }

  .footer__legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
  }

  .footer__legal-link {
    font-size: 0.78rem;
    color: rgba(248, 249, 250, 0.4);
    transition: color var(--transition);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer__legal-link:hover {
    color: rgba(248, 249, 250, 0.7);
  }

  /* ---- Responsive ---- */
  @media (min-width: 640px) {
    .footer__top {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  @media (min-width: 1024px) {
    .footer__top {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
</style>
