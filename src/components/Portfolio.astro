---
const projects = [
  {
    title: 'Liga Manchego CF',
    type: 'Streaming',
    badge: 'streaming',
    description: 'Retransmisiones en directo de la liga para CMM Play. Producción multi-cámara con grafismo en tiempo real.',
    icon: `<svg width="64" height="64" viewBox="0 0 64 64" fill="none">
      <circle cx="32" cy="32" r="28" fill="rgba(230,57,70,0.15)" stroke="rgba(230,57,70,0.3)" stroke-width="1.5"/>
      <path d="M26 22 L42 32 L26 42 Z" fill="#E63946"/>
    </svg>`,
    tags: ['CMM Play', 'Fútbol', 'Multi-cámara'],
    color: '#E63946',
  },
  {
    title: 'Quixote World Cup',
    type: 'Producción',
    badge: 'produccion',
    description: 'Cobertura completa del Campeonato Mundial de Inline Freestyle. Documental, highlights y streaming.',
    icon: `<svg width="64" height="64" viewBox="0 0 64 64" fill="none">
      <circle cx="32" cy="32" r="28" fill="rgba(16,185,129,0.15)" stroke="rgba(16,185,129,0.3)" stroke-width="1.5"/>
      <path d="M20 28 L32 20 L44 28 L44 40 L32 48 L20 40 Z" fill="none" stroke="#10b981" stroke-width="2"/>
      <circle cx="32" cy="34" r="4" fill="#10b981"/>
    </svg>`,
    tags: ['Freestyle', 'Internacional', 'Documental'],
    color: '#10b981',
  },
  {
    title: 'BM Caserío',
    type: 'Streaming',
    badge: 'streaming',
    description: 'Retransmisión de los partidos de balonmano en directo vía YouTube. Cobertura de la temporada completa.',
    icon: `<svg width="64" height="64" viewBox="0 0 64 64" fill="none">
      <circle cx="32" cy="32" r="28" fill="rgba(230,57,70,0.15)" stroke="rgba(230,57,70,0.3)" stroke-width="1.5"/>
      <path d="M22 22 L42 22 L42 42 L22 42 Z" fill="none" stroke="#E63946" stroke-width="2"/>
      <circle cx="32" cy="32" r="6" fill="#E63946"/>
    </svg>`,
    tags: ['Balonmano', 'YouTube', 'Liga'],
    color: '#E63946',
  },
  {
    title: 'CaMaReAnDo',
    type: 'Contenido',
    badge: 'contenido',
    description: 'Serie de contenido propio sobre cultura, deporte y vida en Ciudad Real. Producción editorial y creativa.',
    icon: `<svg width="64" height="64" viewBox="0 0 64 64" fill="none">
      <circle cx="32" cy="32" r="28" fill="rgba(244,114,182,0.15)" stroke="rgba(244,114,182,0.3)" stroke-width="1.5"/>
      <path d="M18 32 Q26 22 32 32 Q38 42 46 32" stroke="#ec4899" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <circle cx="32" cy="32" r="3" fill="#ec4899"/>
    </svg>`,
    tags: ['Original', 'Ciudad Real', 'Serie'],
    color: '#ec4899',
  },
];
---

<section class="portfolio section section--dark" id="portfolio">
  <div class="container">
    <!-- Header -->
    <div class="portfolio__header reveal">
      <span class="section-label section-label--gold">Nuestro trabajo</span>
      <h2 class="portfolio__title">Trabajos Destacados</h2>
      <hr class="divider divider--gold" />
      <p class="portfolio__intro">
        Proyectos que reflejan nuestra pasión por la imagen y el directo.
        Cada producción cuenta una historia única.
      </p>
    </div>

    <!-- Grid -->
    <div class="portfolio__grid">
      {projects.map((project, i) => (
        <article class={`portfolio-card reveal reveal-delay-${i + 1}`} style={`--card-color: ${project.color}`}>
          <div class="portfolio-card__visual">
            <div class="portfolio-card__icon" set:html={project.icon} />
            <span class={`badge badge--${project.badge} portfolio-card__badge`}>{project.type}</span>
          </div>
          <div class="portfolio-card__body">
            <h3 class="portfolio-card__title">{project.title}</h3>
            <p class="portfolio-card__description">{project.description}</p>
            <div class="portfolio-card__tags">
              {project.tags.map(tag => (
                <span class="portfolio-card__tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="portfolio__cta reveal">
      <a href="#contacto" class="btn btn--primary">Trabaja con Nosotros</a>
    </div>
  </div>
</section>

<style>
  .portfolio__header {
    max-width: 560px;
    margin-bottom: 3rem;
  }

  .portfolio__title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--color-text-light);
    margin-bottom: 0;
  }

  .portfolio__intro {
    color: rgba(248, 249, 250, 0.6);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .portfolio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  /* ---- Card ---- */
  .portfolio-card {
    background-color: #242424;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .portfolio-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
    border-color: rgba(var(--card-color), 0.3);
    border-color: color-mix(in srgb, var(--card-color) 30%, transparent);
  }

  .portfolio-card__visual {
    position: relative;
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .portfolio-card__icon {
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.3));
  }

  .portfolio-card__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }

  .portfolio-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .portfolio-card__title {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text-light);
  }

  .portfolio-card__description {
    font-size: 0.88rem;
    color: rgba(248, 249, 250, 0.55);
    line-height: 1.6;
  }

  .portfolio-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .portfolio-card__tag {
    padding: 0.2rem 0.6rem;
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    font-size: 0.72rem;
    color: rgba(248, 249, 250, 0.5);
    font-family: var(--font-heading);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .portfolio__cta {
    display: flex;
    justify-content: center;
    padding-top: 1rem;
  }

  /* ---- Responsive ---- */
  @media (min-width: 640px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portfolio__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
