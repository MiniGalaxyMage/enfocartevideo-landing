---
const services = [
  {
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="40" height="40" rx="10" fill="rgba(230,57,70,0.12)"/>
      <circle cx="20" cy="20" r="6" fill="#E63946"/>
      <path d="M20 8 A12 12 0 0 1 32 20" stroke="#E63946" stroke-width="2" stroke-linecap="round" fill="none"/>
      <path d="M20 8 A12 12 0 0 0 8 20" stroke="rgba(230,57,70,0.4)" stroke-width="2" stroke-linecap="round" fill="none"/>
      <circle cx="20" cy="8" r="2" fill="#E63946"/>
    </svg>`,
    title: 'Streaming en Directo',
    description: 'Retransmisiones multi-cámara profesionales para eventos deportivos. Colaboramos con CMM Play (Castilla-La Mancha Media) llevando el deporte a cualquier pantalla.',
    badge: 'streaming',
    badgeLabel: 'En Directo',
    highlights: ['Multi-cámara', 'CMM Play', 'YouTube & Twitch'],
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="40" height="40" rx="10" fill="rgba(212,160,23,0.12)"/>
      <rect x="8" y="14" width="24" height="18" rx="3" stroke="#D4A017" stroke-width="2" fill="none"/>
      <circle cx="20" cy="23" r="5" stroke="#D4A017" stroke-width="2" fill="none"/>
      <rect x="16" y="10" width="8" height="6" rx="1.5" stroke="#D4A017" stroke-width="1.5" fill="none"/>
      <circle cx="28" cy="17" r="2" fill="#D4A017"/>
    </svg>`,
    title: 'Fotografía Deportiva',
    description: 'Captura la intensidad del momento. Partidos, competiciones y atletas en su máxima expresión. Imágenes que transmiten la emoción del deporte en vivo.',
    badge: 'foto',
    badgeLabel: 'Fotografía',
    highlights: ['Eventos deportivos', 'Alta resolución', 'Entrega rápida'],
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="40" height="40" rx="10" fill="rgba(99,102,241,0.12)"/>
      <rect x="6" y="12" width="22" height="16" rx="3" stroke="#6366f1" stroke-width="2" fill="none"/>
      <path d="M28 16 L34 13 L34 27 L28 24 Z" stroke="#6366f1" stroke-width="2" stroke-linejoin="round" fill="none"/>
      <path d="M13 20 L17 24 L24 16" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    title: 'Vídeo Publicitario',
    description: 'Spots, reels y contenido audiovisual para marcas y negocios. Storytelling visual que conecta con tu audiencia y potencia tu imagen de marca.',
    badge: 'video',
    badgeLabel: 'Publicidad',
    highlights: ['Spots TV & digital', 'Reels sociales', 'Branded content'],
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="40" height="40" rx="10" fill="rgba(16,185,129,0.12)"/>
      <rect x="8" y="10" width="24" height="20" rx="3" stroke="#10b981" stroke-width="2" fill="none"/>
      <path d="M8 16 L32 16" stroke="#10b981" stroke-width="1.5"/>
      <circle cx="12" cy="13" r="1.5" fill="#10b981"/>
      <circle cx="17" cy="13" r="1.5" fill="rgba(16,185,129,0.5)"/>
      <circle cx="22" cy="13" r="1.5" fill="rgba(16,185,129,0.3)"/>
      <path d="M14 24 L20 20 L26 24" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    title: 'Producción de Eventos',
    description: 'Cobertura completa de principio a fin: planificación, grabación, edición y entrega. Tu evento merece ser recordado con la calidad que se merece.',
    badge: 'produccion',
    badgeLabel: 'Producción',
    highlights: ['Planificación', 'Grabación & edición', 'Post-producción'],
  },
];
---

<section class="services section section--light" id="servicios">
  <div class="container">
    <!-- Header -->
    <div class="services__header reveal">
      <span class="section-label">Lo que hacemos</span>
      <h2 class="services__title">Nuestros Servicios</h2>
      <hr class="divider" />
      <p class="services__intro">
        Del directo a la pantalla, del campo al pixel. Ofrecemos una producción audiovisual completa
        adaptada a tus necesidades y presupuesto.
      </p>
    </div>

    <!-- Grid -->
    <div class="services__grid">
      {services.map((service, i) => (
        <article class={`service-card reveal reveal-delay-${i + 1}`}>
          <div class="service-card__icon" set:html={service.icon} />
          <div class="service-card__body">
            <div class="service-card__meta">
              <span class={`badge badge--${service.badge}`}>{service.badgeLabel}</span>
            </div>
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__description">{service.description}</p>
            <ul class="service-card__highlights">
              {service.highlights.map(h => (
                <li class="service-card__highlight">
                  <span class="service-card__check" aria-hidden="true">✓</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="services__cta reveal">
      <p class="services__cta-text">¿Necesitas algo personalizado?</p>
      <a href="#contacto" class="btn btn--primary">Cuéntanos tu proyecto</a>
    </div>
  </div>
</section>

<style>
  .services__header {
    max-width: 560px;
    margin-bottom: 3rem;
  }

  .services__title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--color-text-dark);
    margin-bottom: 0;
  }

  .services__intro {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  /* ---- Card ---- */
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background-color: #fff;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-card);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    border-color: rgba(230, 57, 70, 0.2);
  }

  .service-card__icon {
    flex-shrink: 0;
  }

  .service-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .service-card__title {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-text-dark);
    line-height: 1.2;
  }

  .service-card__description {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .service-card__highlights {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .service-card__highlight {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-dark);
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .service-card__check {
    color: var(--color-secondary);
    font-weight: 900;
    font-size: 0.85rem;
  }

  /* ---- CTA ---- */
  .services__cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    padding-top: 1rem;
  }

  .services__cta-text {
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  /* ---- Responsive ---- */
  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .service-card {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  @media (min-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .service-card {
      flex-direction: column;
    }

    .services__cta {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>
