---
const values = [
  {
    icon: '🎯',
    title: 'Precisión',
    text: 'Cada plano es una decisión. Capturamos el momento exacto.',
  },
  {
    icon: '⚡',
    title: 'Agilidad',
    text: 'Producción dinámica adaptada al ritmo del deporte en vivo.',
  },
  {
    icon: '🎨',
    title: 'Creatividad',
    text: 'Storytelling visual único para cada proyecto y cliente.',
  },
  {
    icon: '🤝',
    title: 'Compromiso',
    text: 'Tu evento importa. Nos implicamos desde la planificación hasta la entrega.',
  },
];
---

<section class="about section section--dark" id="nosotros">
  <div class="container">
    <div class="about__grid">
      <!-- Left: Text -->
      <div class="about__text-col">
        <div class="reveal">
          <span class="section-label section-label--gold">Quiénes somos</span>
          <h2 class="about__title">Pasión por<br><span class="about__title-accent">la Imagen</span></h2>
          <hr class="divider divider--gold" />
        </div>

        <p class="about__body reveal reveal-delay-1">
          EnfocarteVideo nace de la pasión por contar historias a través de la imagen.
          Con experiencia en producción audiovisual y streaming deportivo, llevamos
          la emoción del directo a cualquier pantalla.
        </p>

        <p class="about__body reveal reveal-delay-2">
          Desde Ciudad Real, cubrimos eventos deportivos de toda Castilla-La Mancha
          y colaboramos con medios regionales como CMM Play para llevar el deporte
          local a las casas de todos los aficionados.
        </p>

        <div class="about__location reveal reveal-delay-3">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M9 1.5C6.51 1.5 4.5 3.51 4.5 6c0 3.375 4.5 10.5 4.5 10.5S13.5 9.375 13.5 6c0-2.49-2.01-4.5-4.5-4.5Zm0 6.75a2.25 2.25 0 1 1 0-4.5 2.25 2.25 0 0 1 0 4.5Z" fill="#D4A017"/>
          </svg>
          <span>Ciudad Real, Castilla-La Mancha</span>
        </div>

        <!-- Social links -->
        <div class="about__social reveal reveal-delay-4">
          <a
            href="https://www.instagram.com/enfocartevideo"
            target="_blank"
            rel="noopener noreferrer"
            class="about__social-link"
            aria-label="Instagram de EnfocarteVideo"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
            @enfocartevideo
            <span class="about__social-count">608 seguidores</span>
          </a>

          <a
            href="https://www.youtube.com/@dnkixote"
            target="_blank"
            rel="noopener noreferrer"
            class="about__social-link"
            aria-label="YouTube de EnfocarteVideo"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58Z" stroke="currentColor" stroke-width="2"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" stroke="currentColor" stroke-width="2" fill="currentColor"/>
            </svg>
            @dnkixote
          </a>
        </div>
      </div>

      <!-- Right: Values -->
      <div class="about__values-col">
        <div class="about__values">
          {values.map((value, i) => (
            <div class={`about__value reveal reveal-delay-${i + 1}`}>
              <span class="about__value-icon" aria-hidden="true">{value.icon}</span>
              <div>
                <h3 class="about__value-title">{value.title}</h3>
                <p class="about__value-text">{value.text}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Decorative element -->
        <div class="about__deco reveal">
          <div class="about__deco-inner">
            <svg width="120" height="120" viewBox="0 0 120 120" fill="none" aria-hidden="true">
              <circle cx="60" cy="60" r="55" stroke="rgba(212,160,23,0.15)" stroke-width="1.5"/>
              <circle cx="60" cy="60" r="40" stroke="rgba(212,160,23,0.1)" stroke-width="1"/>
              <circle cx="60" cy="60" r="22" stroke="rgba(230,57,70,0.2)" stroke-width="1"/>
              <path d="M46 60 L60 50 L74 60 L60 70 Z" fill="rgba(230,57,70,0.4)" stroke="#E63946" stroke-width="1.5"/>
            </svg>
            <p class="about__deco-text">Producción<br>con propósito</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .about__title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--color-text-light);
    margin-bottom: 0;
  }

  .about__title-accent {
    color: var(--color-accent);
  }

  .about__body {
    color: rgba(248, 249, 250, 0.7);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .about__location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(248, 249, 250, 0.5);
    font-size: 0.88rem;
    font-weight: 500;
    margin-top: 0.5rem;
  }

  /* ---- Social ---- */
  .about__social {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .about__social-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: rgba(248, 249, 250, 0.7);
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-heading);
    transition: color var(--transition);
    text-decoration: none;
  }

  .about__social-link:hover {
    color: var(--color-text-light);
  }

  .about__social-count {
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-left: 0.25rem;
  }

  /* ---- Values ---- */
  .about__values {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about__value {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    transition: background-color var(--transition), border-color var(--transition);
  }

  .about__value:hover {
    background-color: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .about__value-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .about__value-title {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }

  .about__value-text {
    font-size: 0.85rem;
    color: rgba(248, 249, 250, 0.55);
    line-height: 1.5;
  }

  /* ---- Decorative ---- */
  .about__deco {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .about__deco-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .about__deco-text {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(248, 249, 250, 0.3);
    text-align: center;
    line-height: 1.5;
  }

  /* ---- Responsive ---- */
  @media (min-width: 1024px) {
    .about__grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }
</style>
